{
  "name": "aracli",
  "version": "0.3.0",
  "private": false,
  "description": "Ara engineer CLI (aracli) — skills, worktrees, dev env. Also reachable as `ae` during the renaming window.",
  "type": "module",
  "bin": {
    "aracli": "./bin/aracli",
    "ae": "./bin/aracli"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "typecheck": "tsc --noEmit",
    "build": "bun build src/index.ts --compile --outfile bin/aracli-compiled"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.5.0"
  }
}
