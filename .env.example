# Server
PORT=3000
BASE_URL=https://ara-connectors-production.up.railway.app

# OAuth signing key (generate with: openssl rand -hex 32)
JWT_SECRET=change-me-to-a-random-secret

# Google OAuth (for login page)
# Create at: https://console.cloud.google.com/apis/credentials
# Redirect URI: https://ara-connectors-production.up.railway.app/oauth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Proxy shared secret (for machine-to-machine auth)
PROXY_SECRET=

# Downstream API keys — stored here, never exposed to clients
INSTACART_API_KEY=
HIGGSFIELD_API_KEY=
