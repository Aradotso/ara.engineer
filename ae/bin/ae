#!/usr/bin/env bash
# ae — entry shim. Execs bun on the TypeScript CLI.
# Resolves the real path so symlinks (e.g. ~/.bun/bin/ae → repo) work.
set -e
SELF="$(readlink "$0" 2>/dev/null || echo "$0")"
if [[ "$SELF" != /* ]]; then
  SELF="$(cd "$(dirname "$0")" && pwd)/$(basename "$SELF")"
fi
AE_DIR="$(cd "$(dirname "$SELF")/.." && pwd)"
exec bun "$AE_DIR/src/index.ts" "$@"
